# Auto normalize line endings for all text files
* text=auto

# HTML, CSS, JavaScript
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# Images (binary)
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.webp binary

# Documents
*.pdf binary
*.doc binary
*.docx binary
